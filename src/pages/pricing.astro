---
// src/pages/pricing.astro
import Base from '@/layouts/Base.astro';
---
<Base title="Pricing" description="Simple, transparent pricing for all theContext tools.">
  <div class="container pricing-page">
    <header style="text-align:center;padding:4rem 0 3rem;">
      <p class="section-label">Pricing</p>
      <h1>Simple, <span class="gradient-text">honest</span> pricing</h1>
      <p style="color:var(--color-muted);margin-top:1rem;max-width:480px;margin-inline:auto;">
        All tools are perpetual or annual. No hidden fees.
        VAT included at checkout via Paddle.
      </p>
    </header>

    <div class="pricing-table">
      {[
        { product: '5Q Basic',           price: '$49', period: '/yr · per machine',  link: '/products/5q' },
        { product: '5Q Pro',             price: '$99', period: '/yr · per machine',  link: '/products/5q' },
        { product: '5Q Enterprise',      price: 'Contact', period: 'site license',   link: '/products/5q' },
        { product: 'hanset Annual',      price: '$29', period: '/yr · per machine',  link: '/products/hanset' },
        { product: 'hanset Perpetual',   price: '$79', period: 'one-time',           link: '/products/hanset' },
        { product: 'Lang Pack (single)', price: '$9',  period: 'one-time per pack',  link: '/products/lang-packs' },
        { product: 'Lang Pack Bundle',   price: '$49', period: 'all 70+ packs',      link: '/products/lang-packs' },
        { product: 'Preset (single)',    price: '$12', period: 'one-time',           link: '/products/presets' },
        { product: 'Preset Bundle',      price: '$39', period: 'all presets',        link: '/products/presets' },
      ].map(({ product, price, period, link }) => (
        <div class="pricing-row card">
          <div class="pr-name"><a href={link}>{product}</a></div>
          <div class="pr-price">
            <span class="price">{price}</span>
            <span class="price-note">{period}</span>
          </div>
          <a href={link} class="btn btn--outline btn--sm">Details</a>
        </div>
      ))}
    </div>

    <p class="footnote">
      All prices in USD. VAT/tax calculated at checkout based on your location.
      Licenses are delivered by email within minutes of purchase.
    </p>
  </div>
</Base>

<style>
.pricing-page { max-width:700px; padding-bottom:6rem; }
.gradient-text {
  background:linear-gradient(135deg,var(--color-accent),var(--color-accent2));
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.pricing-table { display:flex; flex-direction:column; gap:0.75rem; }
.pricing-row {
  display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:0.75rem; padding:1rem 1.25rem;
}
.pr-name { font-weight:600; min-width:180px; }
.pr-price { display:flex; align-items:baseline; gap:0.5rem; flex:1; }
.price { font-size:1.15rem; font-weight:800; }
.price-note { font-size:0.78rem; color:var(--color-muted); }
.btn--sm { padding:0.4rem 0.9rem; font-size:0.82rem; white-space:nowrap; }
.footnote {
  margin-top:2rem; font-size:0.82rem; color:var(--color-muted);
  border-top:1px solid var(--color-border); padding-top:1.5rem;
}
</style>
