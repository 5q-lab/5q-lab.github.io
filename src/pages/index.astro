---
// src/pages/index.astro
import Base from '@/layouts/Base.astro';
import Hero from '@/components/Hero.astro';
import ProductCard from '@/components/ProductCard.astro';

// ── Product definitions ──────────────────────────────────────────
// TODO: Replace paddlePriceId values after Paddle account setup
const products = [
  {
    name: '5Q Prompt',
    tagline: 'Five-Quality offline prompt analyzer',
    badge: 'CLI Tool',
    badgeVariant: 'sky' as const,
    description:
      'Diagnose AI prompts across five dimensions (Metal/Wood/Water/Fire/Earth) entirely offline. Works with any LLM. Includes semantic engine and fractal analysis.',
    features: [
      'Offline-first — no data leaves your machine',
      'Wuxing five-quality scoring model',
      'Semantic engine (ONNX / Candle)',
      'Multi-language prompt support',
      'Industry-specific profiles',
    ],
    price: 'USD 49 / yr',
    priceNote: 'per machine · Basic tier',
    paddlePriceId: 'pri_PLACEHOLDER_5Q_BASIC',
    href: '/products/5q',
  },
  {
    name: 'hanset',
    tagline: 'Context anchor & environment config manager',
    badge: 'CLI Tool',
    badgeVariant: 'indigo' as const,
    description:
      'Inject structured project context into any AI session automatically. Manages environment configs, anchors, and team knowledge bases.',
    features: [
      'Auto-context injection at session start',
      'Multi-env config management',
      'Team knowledge base anchoring',
      'License-gated — works alongside 5Q',
      'macOS / Linux',
    ],
    price: 'USD 29 / yr',
    priceNote: 'per machine',
    paddlePriceId: 'pri_PLACEHOLDER_HANSET',
    href: '/products/hanset',
  },
  {
    name: '5Q Lang Packs',
    tagline: 'Domain-specific vocabulary expansion',
    badge: 'Extension',
    badgeVariant: 'gold' as const,
    description:
      'Extend 5Q with curated vocabulary for banking, medical, legal, game design, and more. Signed .5qpack bundles — install in seconds.',
    features: [
      '70+ packs across 10+ domains',
      'Ed25519-signed for integrity',
      'Single pack or full bundle',
      'Updatable via CLI',
      'Community pack support (roadmap)',
    ],
    price: 'USD 9 / pack',
    priceNote: 'or USD 49 full bundle',
    paddlePriceId: 'pri_PLACEHOLDER_LANGPACK_SINGLE',
    href: '/products/lang-packs',
  },
  {
    name: 'Preset Packs',
    tagline: 'Parameter-tuned profiles for specific workflows',
    badge: 'Extension',
    badgeVariant: 'gold' as const,
    description:
      'Ready-made scoring profiles tuned for specific industries and writing styles. Drop-in presets for 5Q that skip manual calibration.',
    features: [
      'Industry-tuned weight profiles',
      'Writing-style specializations',
      'One-command install',
      'Compatible with all 5Q tiers',
      'Custom preset (Enterprise)',
    ],
    price: 'USD 12 / preset',
    priceNote: 'or bundle with 5Q Pro',
    paddlePriceId: 'pri_PLACEHOLDER_PRESET',
    href: '/products/presets',
  },
];
---

<Base title="Products" description="Professional AI tools from theContext — 5Q, hanset, Lang Packs, and Preset Packs.">

  <!-- Hero -->
  <Hero />

  <!-- Products grid -->
  <section id="products" class="products-section">
    <div class="container">
      <p class="section-label">Products</p>
      <h2>Everything you need to<br />work smarter with AI</h2>
      <p class="section-sub">
        All tools are offline-first, license-verified, and designed for practitioners
        who value privacy and reproducibility.
      </p>

      <div class="products-grid">
        {products.map(p => (
          <ProductCard {...p} />
        ))}
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="trust-section">
    <div class="container trust-inner">
      <div class="trust-item">
        <span class="trust-icon">🔐</span>
        <span>Ed25519-signed licenses</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🖥️</span>
        <span>100% offline operation</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🌍</span>
        <span>VAT handled by Paddle</span>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🦀</span>
        <span>Built in Rust</span>
      </div>
    </div>
  </section>

  <!-- Paddle init script -->
  <script>
    // Initialize Paddle Billing
    // TODO: Replace with real Paddle client-side token after account setup
    const PADDLE_CLIENT_TOKEN = 'test_PLACEHOLDER';
    const PADDLE_ENV: 'sandbox' | 'production' = 'sandbox'; // flip to 'production' on launch

    declare const Paddle: any;

    document.addEventListener('DOMContentLoaded', () => {
      if (typeof Paddle === 'undefined') return;

      Paddle.Environment.set(PADDLE_ENV);
      Paddle.Initialize({ token: PADDLE_CLIENT_TOKEN });

      // Wire up all Buy buttons
      document.querySelectorAll<HTMLButtonElement>('.paddle-checkout-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const priceId = btn.dataset.priceId;
          if (!priceId || priceId.includes('PLACEHOLDER')) {
            alert('Checkout coming soon — pricing is being finalized.');
            return;
          }
          Paddle.Checkout.open({
            items: [{ priceId, quantity: 1 }],
            settings: { displayMode: 'overlay', theme: 'dark' },
          });
        });
      });
    });
  </script>
</Base>

<style>
/* Products section */
.products-section { padding: var(--section-py) 0; }
.section-sub {
  color: var(--color-muted);
  max-width: 560px;
  margin-top: 0.75rem;
  margin-bottom: 3rem;
  font-size: 0.975rem;
}
.products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}

/* Trust bar */
.trust-section {
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding: 2rem 0;
}
.trust-inner {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 2.5rem;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.9rem;
  color: var(--color-muted);
}
.trust-icon { font-size: 1.15rem; }
</style>
