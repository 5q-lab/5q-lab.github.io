---
// src/pages/products/presets.astro
import Base from '@/layouts/Base.astro';
---
<Base title="5Q Preset Packs" description="Parameter-tuned scoring profiles for 5Q Prompt Analyzer.">
  <div class="container product-page">
    <a href="/" class="back-link">← All products</a>

    <header class="product-hero">
      <span class="badge badge--gold">Extension</span>
      <h1>Preset <span class="gradient-text">Packs</span></h1>
      <p class="product-hero-sub">
        Drop-in scoring profiles with pre-tuned weights for specific industries
        and writing styles. Skip weeks of manual calibration.
      </p>
    </header>

    <section class="pricing-row">
      <div class="card price-option">
        <h3>Single Preset</h3>
        <div class="tier-price"><span class="price">$12</span><span class="price-note">one-time per preset</span></div>
        <button class="btn btn--outline paddle-checkout-btn" data-price-id="pri_PLACEHOLDER_PRESET_SINGLE" style="width:100%;justify-content:center;margin-top:1rem;">Browse &amp; buy</button>
      </div>
      <div class="card price-option tier-card--highlight">
        <h3>Preset Bundle</h3>
        <div class="tier-price"><span class="price">$39</span><span class="price-note">all presets · one-time</span></div>
        <button class="btn btn--primary paddle-checkout-btn" data-price-id="pri_PLACEHOLDER_PRESET_BUNDLE" style="width:100%;justify-content:center;margin-top:1rem;">Get bundle</button>
      </div>
      <div class="card price-option">
        <h3>Custom Preset</h3>
        <div class="tier-price"><span class="price">Contact</span><span class="price-note">Enterprise only</span></div>
        <a href="mailto:support@thecontext.dev" class="btn btn--outline" style="width:100%;justify-content:center;margin-top:1rem;">Get in touch</a>
      </div>
    </section>

    <section style="margin-top:3rem;">
      <p class="section-label">Available presets</p>
      <p style="color:var(--color-muted);margin-top:0.5rem;">
        Preset catalog is being finalized. Contact us for early access.
      </p>
    </section>
  </div>
</Base>

<style>
.product-page { padding:3rem 0 6rem; max-width:860px; }
.back-link { color:var(--color-muted); font-size:0.875rem; }
.back-link:hover { color:var(--color-text); }
.product-hero { margin:2rem 0 3rem; display:flex; flex-direction:column; gap:1rem; }
.product-hero-sub { color:var(--color-muted); max-width:560px; }
.gradient-text {
  background:linear-gradient(135deg,var(--color-gold),#f97316);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent;
}
.pricing-row { display:flex; gap:1.25rem; flex-wrap:wrap; }
.price-option { flex:1; min-width:180px; }
.tier-card--highlight { border-color:var(--color-gold); }
.tier-price { display:flex; flex-direction:column; margin-top:0.5rem; }
.price { font-size:1.6rem; font-weight:800; }
.price-note { font-size:0.75rem; color:var(--color-muted); }
</style>
