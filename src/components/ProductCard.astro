---
// src/components/ProductCard.astro
interface Props {
  name: string;
  tagline: string;
  badge: string;
  badgeVariant?: 'sky' | 'gold' | 'indigo';
  description: string;
  features: string[];
  price: string;         // e.g. "USD 49 / yr"
  priceNote?: string;    // e.g. "per machine"
  paddlePriceId: string; // Paddle Billing price_id (filled after Paddle setup)
  href: string;          // detail page
}

const {
  name,
  tagline,
  badge,
  badgeVariant = 'sky',
  description,
  features,
  price,
  priceNote,
  paddlePriceId,
  href,
} = Astro.props;
---

<article class="card product-card">
  <header class="card-header">
    <span class={`badge badge--${badgeVariant}`}>{badge}</span>
    <h3 class="product-name">{name}</h3>
    <p class="product-tagline">{tagline}</p>
  </header>

  <p class="product-desc">{description}</p>

  <ul class="feature-list">
    {features.map(f => (
      <li><span class="check">✓</span>{f}</li>
    ))}
  </ul>

  <footer class="card-footer">
    <div class="price-block">
      <span class="price">{price}</span>
      {priceNote && <span class="price-note">{priceNote}</span>}
    </div>
    <div class="card-actions">
      <a href={href} class="btn btn--outline btn--sm">Learn more</a>
      <!-- Paddle checkout is triggered by JS; data-price-id picked up by paddle-init.js -->
      <button
        class="btn btn--primary btn--sm paddle-checkout-btn"
        data-price-id={paddlePriceId}
      >
        Buy now
      </button>
    </div>
  </footer>
</article>

<style>
.product-card {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.card-header { display: flex; flex-direction: column; gap: 0.4rem; }
.product-name { font-size: 1.2rem; font-weight: 700; margin-top: 0.25rem; }
.product-tagline { color: var(--color-muted); font-size: 0.9rem; }
.product-desc { color: var(--color-muted); font-size: 0.9rem; line-height: 1.6; }

.feature-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}
.feature-list li {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: var(--color-text);
}
.check { color: var(--color-accent); font-weight: 700; flex-shrink: 0; }

.card-footer { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.75rem; margin-top: auto; }
.price-block { display: flex; flex-direction: column; }
.price { font-size: 1.3rem; font-weight: 800; }
.price-note { font-size: 0.75rem; color: var(--color-muted); }

.card-actions { display: flex; gap: 0.5rem; }
.btn--sm { padding: 0.45rem 1rem; font-size: 0.85rem; }
</style>
